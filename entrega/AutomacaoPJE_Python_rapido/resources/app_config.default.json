{
  "pje_calc": {
    "base_url": "http://localhost:9257/pjecalc",
    "startup_timeout_seconds": 120,
    "element_timeout_seconds": 30,
    "operation_timeout_seconds": 180,
    "optional_executable_path": null
  },
  "browser": {
    "name": "chrome",
    "headless": false,
    "firefox_binary": "C:\\Program Files\\Mozilla Firefox\\firefox.exe",
    "chrome_binary": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
    "geckodriver_path": null
  },
  "execution": {
    "test_mode_first_record_only": false,
    "max_retries_per_step": 1,
    "max_retries_pje_server_error": 3,
    "output_retry_attempts": 2,
    "resume_recent_calculation": true,
    "idle_alert_timeout_seconds": 0.15,
    "regeneration_confirm_timeout_seconds": 8,
    "step_delay_ms": 0,
    "liquidation_menu_settle_seconds": 1.0,
    "liquidation_execute_settle_seconds": 2.0,
    "liquidation_timeout_seconds": 300,
    "retry_backoff_seconds": 2,
    "continue_on_record_error": true,
    "resume_previous_run": true,
    "overwrite_valid_outputs": false,
    "cooldown_every_records": 5,
    "cooldown_seconds": 120,
    "failed_record_revisit_rounds": 1,
    "reuse_browser_session": true,
    "cooldown_every_records_correction": 0,
    "cooldown_seconds_correction": 0,
    "record_watchdog_timeout_seconds": 120,
    "watchdog_poll_seconds": 3,
    "minimize_browser_window": true
  },
  "output": {
    "mask_cpf_in_logs": true,
    "take_screenshot_on_error": true,
    "save_html_on_error": true
  },
  "history_paste": {
    "strategy": "selenium_execute_async_script",
    "delay_ms": 0,
    "dispatch_input": true,
    "dispatch_change": true,
    "dispatch_blur": true,
    "validate_first_last_and_count": true
  }
}
